# Copy this file to .env and fill in your real values.
# NEVER commit .env because it contains secrets.

# LLM runtime
# Supported values:
#   LLM_PROVIDER=bedrock
#   LLM_PROVIDER=lmstudio
LLM_PROVIDER=bedrock
LLM_MODEL_ID=amazon.nova-pro-v1:0

# AWS Bedrock credentials (required when LLM_PROVIDER=bedrock)
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
# If you use temporary AWS credentials, also set this:
AWS_SESSION_TOKEN=
AWS_DEFAULT_REGION=us-east-1

# LM Studio endpoint (required when LLM_PROVIDER=lmstudio)
# Example: http://127.0.0.1:1234
LM_STUDIO_ENDPOINT=http://127.0.0.1:1234
LM_STUDIO_API_KEY=lm-studio

# Cisco DevNet Sandbox device access
DEVICE_TYPE=cisco_ios
DEVICE_HOST=devnetsandboxiosxec8k.cisco.com
DEVICE_PORT=22
DEVICE_USERNAME=your-sandbox-username
DEVICE_PASSWORD=your-sandbox-password

# Batfish service
BATFISH_HOST=127.0.0.1

# Persistent network memory
NETWORK_MEMORY_PATH=memory/network_memory.json
NETWORK_MEMORY_AUTO_REFRESH=true
NETWORK_MEMORY_ENABLE_TOPOLOGY=true
