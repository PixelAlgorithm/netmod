! Cisco IOS Configuration
version 15.2
hostname {{ deployment_target | default('NETWORK-DEVICE') | upper }}
!

{% for obj in network_objects %}
{% if obj.type == "vlan" %}
vlan {{ obj.id }}
 name {{ obj.name }}
!
interface vlan {{ obj.id }}
 description {{ obj.name }} network
{% if obj.gateway is defined and obj.subnet is defined %}
 ip address {{ obj.gateway }} {{ obj.subnet | netmask }}
{% endif %}
 no shutdown
!
{% endif %}
{% endfor %}

{% for obj in network_objects %}
{% if obj.type == "vlan" and "enable_dhcp" in actions and obj.subnet is defined %}
ip dhcp pool {{ obj.name }}_dhcp
 network {{ obj.subnet | network_addr }} {{ obj.subnet | netmask }}
{% if obj.gateway is defined %}
 default-router {{ obj.gateway }}
{% endif %}
{% if obj.dns_servers is defined %}
{% for dns in obj.dns_servers %}
 dns-server {{ dns }}
{% endfor %}
{% endif %}
!
{% endif %}
{% endfor %}

{% for policy in security_policies %}
{% if policy.destination == "internet" %}
{% set dest = "any" %}
{% else %}
{% set dest = policy.destination | network_addr + " " + (policy.destination | wildcard) %}
{% endif %}
{% if policy.action == "deny" %}
access-list 100 deny ip any {{ dest }}
{% elif policy.action == "allow" %}
access-list 100 permit ip any {{ dest }}
{% endif %}
{% endfor %}

end